      <CodeComponent name="stimuliCode" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="/*&amp;#10;This script generates trial sequences for the n-back task*/&amp;#10;import * as pd from 'pandas';&amp;#10;var expectedResponse, letterPool, sequenceDataset, sequenceOk, sequenceRandom, threeconsletters, threeconsmatches, toggleSwitch, trialAll_num, trialMatch_num_expected, trialMatch_num_observed, trialMatch_observed;&amp;#10;letterPool = ([&quot;A&quot;, &quot;E&quot;, &quot;I&quot;, &quot;U&quot;, &quot;H&quot;, &quot;K&quot;, &quot;M&quot;, &quot;R&quot;] * 2);&amp;#10;trialAll_num = 5;&amp;#10;trialMatch_num_expected = 1;&amp;#10;toggleSwitch = true;&amp;#10;while ((toggleSwitch === true)) {&amp;#10;    sequenceRandom = np.random.choice(letterPool, trialAll_num, true);&amp;#10;    trialMatch_observed = np.zeros(trialAll_num, {&quot;dtype&quot;: bool});&amp;#10;    for (var trialIdx, _pj_c = 0, _pj_a = np.arange(2, trialAll_num), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;        trialIdx = _pj_a[_pj_c];&amp;#10;        if ((sequenceRandom[trialIdx] === sequenceRandom[(trialIdx - 2)])) {&amp;#10;            trialMatch_observed[trialIdx] = true;&amp;#10;        }&amp;#10;    }&amp;#10;    trialMatch_num_observed = util.sum(trialMatch_observed);&amp;#10;    threeconsletters = np.zeros(trialAll_num, {&quot;dtype&quot;: bool});&amp;#10;    for (var trialIdx, _pj_c = 0, _pj_a = np.arange(2, trialAll_num), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;        trialIdx = _pj_a[_pj_c];&amp;#10;        if (((sequenceRandom[trialIdx] === sequenceRandom[(trialIdx - 1)]) &amp;&amp; (sequenceRandom[trialIdx] === sequenceRandom[(trialIdx - 2)]))) {&amp;#10;            threeconsletters[trialIdx] = true;&amp;#10;        }&amp;#10;    }&amp;#10;    threeconsmatches = np.zeros(trialAll_num, {&quot;dtype&quot;: bool});&amp;#10;    for (var trialIdx, _pj_c = 0, _pj_a = np.arange(2, trialAll_num), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;        trialIdx = _pj_a[_pj_c];&amp;#10;        if ((util.sum(trialMatch_observed.slice((trialIdx - 2), (trialIdx + 1))) === 3)) {&amp;#10;            threeconsmatches[trialIdx] = true;&amp;#10;        }&amp;#10;    }&amp;#10;    if ((((trialMatch_num_observed === trialMatch_num_expected) &amp;&amp; (util.sum(threeconsmatches) === 0)) &amp;&amp; (util.sum(threeconsletters) === 0))) {&amp;#10;        toggleSwitch = false;&amp;#10;    }&amp;#10;}&amp;#10;sequenceOk = sequenceRandom;&amp;#10;expectedResponse = np.array(function () {&amp;#10;    var _pj_a = [], _pj_b = np.arange(trialAll_num);&amp;#10;    for (var _pj_c = 0, _pj_d = _pj_b.length; (_pj_c &lt; _pj_d); _pj_c += 1) {&amp;#10;        var _ = _pj_b[_pj_c];&amp;#10;        _pj_a.push(&quot;key2use&quot;);&amp;#10;    }&amp;#10;    return _pj_a;&amp;#10;}&amp;#10;.call(this));&amp;#10;expectedResponse[(trialMatch_observed === true)] = &quot;left&quot;;&amp;#10;expectedResponse[(trialMatch_observed === false)] = &quot;right&quot;;&amp;#10;sequenceDataset = new pd.DataFrame({&quot;trial&quot;: np.arange(1, (trialAll_num + 1)), &quot;letter&quot;: sequenceOk, &quot;nback_match&quot;: trialMatch_observed, &quot;expectedResponse&quot;: expectedResponse, &quot;observedResponse&quot;: np.nan, &quot;Accuracy&quot;: np.nan, &quot;RT_allTrials&quot;: np.nan, &quot;RT_correctTrials&quot;: np.nan});&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="&quot;&quot;&quot;&amp;#10;GENERATE LISTS OF N-BACK STIMULI&amp;#10;&quot;&quot;&quot;&amp;#10;&amp;#10;import numpy as np&amp;#10;import pandas as pd&amp;#10;&amp;#10;&quot;&quot;&quot;&amp;#10;===================================&amp;#10;a. Trial Numbers and Distributions&amp;#10;===================================&amp;#10;&quot;&quot;&quot;&amp;#10;&amp;#10;trialAll_num = 20 # number of trials (must be even)&amp;#10;trialMatch_proportion = 1/2 # proportion of match trials&amp;#10;trialMatch_num_expected = (trialAll_num-2) * trialMatch_proportion  # num of match trials&amp;#10;&amp;#10;&quot;&quot;&quot;&amp;#10;=============================&amp;#10;b. Trial Sequence Generation&amp;#10;=============================&amp;#10;&quot;&quot;&quot;&amp;#10;&amp;#10;# create trial column&amp;#10;trial = 1+np.arange(0,trialAll_num)&amp;#10;&amp;#10;# %%  create nbackMatch column (i.e., a list of True and False)&amp;#10;# criteria:&amp;#10;# 1. the first two trials are False&amp;#10;# 2. no more than two consecutive True (there can be more than two consecutive Flase, to avoid making the sequence a bit predictable)&amp;#10;# 3. same number of True and False&amp;#10;&amp;#10;nbackMatch = np.empty(trialAll_num,dtype=int)   # initialize&amp;#10;&amp;#10;toggleSwitch = 1&amp;#10;while toggleSwitch==1:&amp;#10;    for trialIdx in np.arange(0,trialAll_num):&amp;#10;        if trial[trialIdx]&lt;=2:     # False for the first two trials&amp;#10;            nbackMatch[trialIdx] = 0&amp;#10;        else:  # for the next trials random choice, unless the previous two trials were True (if so pick False)&amp;#10;            if nbackMatch[trialIdx-2]==1  and  nbackMatch[trialIdx-1]==1 :&amp;#10;                nbackMatch[trialIdx] = 0&amp;#10;            else :&amp;#10;                nbackMatch[trialIdx] = np.int64(np.random.randn(1)&gt;0)&amp;#10;&amp;#10;    # evaluate if number of True is half of trial number&amp;#10;    numTrue = sum(nbackMatch)&amp;#10;    if numTrue==trialMatch_num_expected:&amp;#10;        toggleSwitch = 0&amp;#10;&amp;#10;# %% create letter column (i.e., a list of letters)&amp;#10;# criteria:&amp;#10;# 1. use a specific pool of letters&amp;#10;# 2. never the same letter on consecutive trials&amp;#10;&amp;#10;&quot;&quot;&quot;&amp;#10;b.1 Assign Stimuli Pool&amp;#10;&quot;&quot;&quot;&amp;#10;&amp;#10;letter = np.empty(trialAll_num,dtype=&quot;&lt;U6&quot;)&amp;#10;letterPool = [&quot;A&quot;,&quot;E&quot;,&quot;I&quot;,&quot;U&quot;,&quot;H&quot;,&quot;K&quot;,&quot;M&quot;,&quot;R&quot;]&amp;#10;&amp;#10;toggleSwitch2 = 1&amp;#10;while toggleSwitch2==1:&amp;#10;    &amp;#10;    for trialIdx in np.arange(0,trialAll_num):&amp;#10;        if trial[trialIdx]==1:    # 1st trial, pick any letter from the pool&amp;#10;            letter[trialIdx] = np.random.choice(letterPool,1)[0]  # pick one letter from the pool. all letters have equal probability of being picked&amp;#10;        elif trial[trialIdx]==2:   # 2nd trial, remove from the pool the letter used in the previous trial and pick from the remaining letters&amp;#10;            previousletter = letterPool.index(letter[trialIdx-1])    # letter at previous 1 trial&amp;#10;            letterPool_red = np.delete(letterPool, previousletter )  # modified letterPool to remove the letter of the previous trial(s)&amp;#10;            letter[trialIdx] = np.random.choice(letterPool_red,1)[0]   # pick one letter from the modified pool. all letters have equal probability of being picked&amp;#10;        else:                    # 3rd trial onwards&amp;#10;            if nbackMatch[trialIdx]==True:            # if match&amp;#10;                letter[trialIdx] = letter[trialIdx-2] # pick the same letter presented two trials before&amp;#10;            else:                # if non-match, remove from the pool the letters used in the previous two trials and pick from the remaining letters&amp;#10;                previousletter = (letterPool.index(letter[trialIdx-1]),letterPool.index(letter[trialIdx-2]))    # letters of previous 2 trials&amp;#10;                letterPool_red = np.delete(letterPool, previousletter )  # modified letterPool to remove the letter of the previous trial(s)&amp;#10;                letter[trialIdx] = np.random.choice(letterPool_red,1)[0]    # pick one letter from the modified pool. all letters have equal probability of being picked&amp;#10;    &amp;#10;    # check that vowels are 50% of the trials&amp;#10;    isvowel = np.zeros(trialAll_num,dtype=int)&amp;#10;    for trialIdx in np.arange(0,trialAll_num):&amp;#10;        isvowel[trialIdx] = letter[trialIdx] in [&quot;A&quot;,&quot;E&quot;,&quot;I&quot;,&quot;U&quot;]&amp;#10;    &amp;#10;    # check that each letter is picked at least 5% of the times &amp;#10;    letterProportion = np.empty(len(letterPool),dtype=float)     &amp;#10;    for poolIdx in np.arange(0,len(letterPool)):&amp;#10;        letterProportion[poolIdx] = sum(letter==letterPool[poolIdx])/trialAll_num&amp;#10;    &amp;#10;    # implement the two checks above&amp;#10;    if sum(isvowel)==trialAll_num/2   and   np.min(letterProportion)&gt;=0.05:&amp;#10;        toggleSwitch2 = 0    &amp;#10;&amp;#10;&quot;&quot;&quot;&amp;#10;========================&amp;#10;c. Assign Response Keys&amp;#10;========================&amp;#10;&quot;&quot;&quot;&amp;#10;&amp;#10;# create expectedResponse&amp;#10;# True=match, False=non-match&amp;#10;expectedResponse = np.array(['key2press' for _ in np.arange(trialAll_num)])&amp;#10;expectedResponse[nbackMatch==1] = &quot;i&quot;&amp;#10;expectedResponse[nbackMatch==0] = &quot;r&quot;&amp;#10;&amp;#10;&quot;&quot;&quot;&amp;#10;========================&amp;#10;d. Initialise DataFrame&amp;#10;========================&amp;#10;&quot;&quot;&quot;&amp;#10;&amp;#10;# build a dataframe from dictionary&amp;#10;sequenceDataset= pd.DataFrame({'trial': trial, &amp;#10;                               'letter': letter, &amp;#10;                               'isvowel': isvowel,&amp;#10;                               'nbackMatch': nbackMatch, &amp;#10;                               'expectedResponse': expectedResponse, &amp;#10;                               'observedResponse': np.nan, &amp;#10;                               'Accuracy': np.nan, &amp;#10;                               'RT_allTrials': np.nan, &amp;#10;                               'RT_correctTrials': np.nan,&amp;#10;                               'trialDuration': np.nan, &amp;#10;                               'step': np.nan})&amp;#10;" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="stimuliCode" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
