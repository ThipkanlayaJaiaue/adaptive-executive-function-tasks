        <Param val="/* Syntax Error: Fix Python code */" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# number of trials&amp;#10;Practice_allTrials_num = np.array(sequenceDataset.trial)[-1] # the last cell in the sequenceDataset.trial colums&amp;#10;&amp;#10;# number of responses (n responses per trial)&amp;#10;Practice_responses_num = numCol*Practice_allTrials_num &amp;#10;&amp;#10;# number of correct responses &amp;#10;Practice_correctResponses_num = np.nansum(sequenceDataset.Accuracy_tot)&amp;#10;&amp;#10;# percentage of correct responses&amp;#10;Practice_correctResponses_pct= 100*Practice_correctResponses_num/Practice_responses_num &amp;#10;&amp;#10;# Mdn response time to all grids&amp;#10;Practice_grid_MdnRT = np.nanmedian(sequenceDataset.RespTime_grid)&amp;#10;&amp;#10;# 3rd quartile (i.e., 75th percentile) RT for only correct responses&amp;#10;Practice_grid_3qrtRT = np.nanpercentile(sequenceDataset.RespTime_grid, 75)&amp;#10;&amp;#10;&amp;#10;# message for feedback&amp;#10;msg = &quot;%i of %i correct responses \n%.2f%% correct \nMdn RespTime = %.2fs &quot; %(Practice_correctResponses_num, Practice_responses_num, Practice_correctResponses_pct, Practice_grid_MdnRT )&amp;#10;    &amp;#10;    &amp;#10;# color of feedback&amp;#10;if Practice_correctResponses_pct&gt;=70:&amp;#10;    fb_col = 'green'     # if accuracy is at least the value above&amp;#10;else:&amp;#10;    fb_col = 'red'" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
