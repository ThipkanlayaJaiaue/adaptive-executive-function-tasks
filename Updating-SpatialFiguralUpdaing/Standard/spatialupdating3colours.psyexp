        <Param val="rowCounter = rowCounter + 1&amp;#10;&amp;#10;# add data about the sequence&amp;#10;thisExp.addData('myPract.trial',    sequenceDataset.trial[rowCounter])&amp;#10;thisExp.addData('myPract.grid',     sequenceDataset.grid[rowCounter])&amp;#10;thisExp.addData('myPract.stimulus', sequenceDataset.stimulus[rowCounter])&amp;#10;&amp;#10;thisExp.addData('myPract.color',     sequenceDataset.color[rowCounter])&amp;#10;thisExp.addData('myPract.position',  sequenceDataset.position[rowCounter])&amp;#10;thisExp.addData('myPract.gridName',  sequenceDataset.gridName[rowCounter])&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
