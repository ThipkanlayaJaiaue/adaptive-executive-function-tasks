  <Flow>
    <Routine name="practiceInstructions"/>
    <Routine name="practiceInstructions2"/>
    <Routine name="practiceInstructions3"/>
    <LoopInitiator loopType="TrialHandler" name="practiceRepetition">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="None" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="False" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="5" valType="num"/>
      <Param name="name" updates="None" val="practiceRepetition" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="startpractice"/>
    <Routine name="sequenceGeneration"/>
    <LoopInitiator loopType="TrialHandler" name="practiceBlock">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="None" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="np.array(sequenceDataset.trial)[-1] " valType="num"/>
      <Param name="name" updates="None" val="practiceBlock" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <LoopInitiator loopType="TrialHandler" name="practiceGrid">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="None" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="sum(sequenceDataset.trial==1+practiceBlock.thisN) " valType="num"/>
      <Param name="name" updates="None" val="practiceGrid" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="practiceTrial"/>
    <LoopTerminator name="practiceGrid"/>
    <LoopInitiator loopType="TrialHandler" name="practiceColor">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'AskImageFile_practice': 'AskBlu.JPG', 'AskColor_practice': 'blu'}, {'AskImageFile_practice': 'AskGre.JPG', 'AskColor_practice': 'gre'}, {'AskImageFile_practice': 'AskYel.JPG', 'AskColor_practice': 'yel'}, {'AskImageFile_practice': 'AskRed.JPG', 'AskColor_practice': 'red'}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="numCol" valType="num"/>
      <Param name="name" updates="None" val="practiceColor" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="practiceResponse"/>
    <Routine name="practiceTrial_feedback"/>
    <LoopTerminator name="practiceColor"/>
    <Routine name="practiceUpdateAccuracy_tot"/>
    <LoopTerminator name="practiceBlock"/>
    <Routine name="practiceBlock_feedback"/>
    <LoopTerminator name="practiceRepetition"/>
    <Routine name="taskInstruction"/>
    <Routine name="starttask"/>
    <Routine name="sequenceGeneration_2"/>
    <LoopInitiator loopType="TrialHandler" name="experimentalBlock">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="None" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="np.array(sequenceDataset.trial)[-1] " valType="num"/>
      <Param name="name" updates="None" val="experimentalBlock" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <LoopInitiator loopType="TrialHandler" name="experimentalGrid">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="None" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="sum(sequenceDataset.trial==1+experimentalBlock.thisN) " valType="num"/>
      <Param name="name" updates="None" val="experimentalGrid" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="experimentalTrial"/>
    <LoopTerminator name="experimentalGrid"/>
    <LoopInitiator loopType="TrialHandler" name="experimentalColor">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'AskImageFile_experimental': 'AskBlu.JPG', 'AskColor_experimental': 'blu'}, {'AskImageFile_experimental': 'AskGre.JPG', 'AskColor_experimental': 'gre'}, {'AskImageFile_experimental': 'AskYel.JPG', 'AskColor_experimental': 'yel'}, {'AskImageFile_experimental': 'AskRed.JPG', 'AskColor_experimental': 'red'}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="numCol" valType="num"/>
      <Param name="name" updates="None" val="experimentalColor" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="experimentalResponse"/>
    <LoopTerminator name="experimentalColor"/>
    <Routine name="experimentalUpdateAccuracy_tot"/>
    <LoopTerminator name="experimentalBlock"/>
    <Routine name="End"/>
  </Flow>
</PsychoPy2experiment>
