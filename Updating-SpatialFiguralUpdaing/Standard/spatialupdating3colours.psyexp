        <Param val="0.1" valType="num" updates="constant" name="letterHeight"/>
        <Param val="waitScreen_2" valType="code" updates="None" name="name"/>
        <Param val="" valType="num" updates="constant" name="opacity"/>
        <Param val="0" valType="num" updates="constant" name="ori"/>
        <Param val="(0, 0)" valType="list" updates="constant" name="pos"/>
        <Param val="False" valType="bool" updates="None" name="saveStartStop"/>
        <Param val="" valType="code" updates="None" name="startEstim"/>
        <Param val="time (s)" valType="str" updates="None" name="startType"/>
        <Param val="0.0" valType="code" updates="None" name="startVal"/>
        <Param val="duration (s)" valType="str" updates="None" name="stopType"/>
        <Param val="0.5" valType="code" updates="constant" name="stopVal"/>
        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="Generating stimuli..." valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>
        <Param val="" valType="num" updates="constant" name="wrapWidth"/>
      </TextComponent>
      <CodeComponent name="stimuli_2" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="/*&amp;#10;This script generates trial sequences for the n-back task*/&amp;#10;import * as pd from 'pandas';&amp;#10;var expectedResponse, letterPool, sequenceDataset, sequenceOk, sequenceRandom, threeconsletters, threeconsmatches, toggleSwitch, trialAll_num, trialMatch_num_expected, trialMatch_num_observed, trialMatch_observed;&amp;#10;letterPool = ([&quot;A&quot;, &quot;E&quot;, &quot;I&quot;, &quot;U&quot;, &quot;H&quot;, &quot;K&quot;, &quot;M&quot;, &quot;R&quot;] * 2);&amp;#10;trialAll_num = 5;&amp;#10;trialMatch_num_expected = 1;&amp;#10;toggleSwitch = true;&amp;#10;while ((toggleSwitch === true)) {&amp;#10;    sequenceRandom = np.random.choice(letterPool, trialAll_num, true);&amp;#10;    trialMatch_observed = np.zeros(trialAll_num, {&quot;dtype&quot;: bool});&amp;#10;    for (var trialIdx, _pj_c = 0, _pj_a = np.arange(2, trialAll_num), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;        trialIdx = _pj_a[_pj_c];&amp;#10;        if ((sequenceRandom[trialIdx] === sequenceRandom[(trialIdx - 2)])) {&amp;#10;            trialMatch_observed[trialIdx] = true;&amp;#10;        }&amp;#10;    }&amp;#10;    trialMatch_num_observed = util.sum(trialMatch_observed);&amp;#10;    threeconsletters = np.zeros(trialAll_num, {&quot;dtype&quot;: bool});&amp;#10;    for (var trialIdx, _pj_c = 0, _pj_a = np.arange(2, trialAll_num), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;        trialIdx = _pj_a[_pj_c];&amp;#10;        if (((sequenceRandom[trialIdx] === sequenceRandom[(trialIdx - 1)]) &amp;&amp; (sequenceRandom[trialIdx] === sequenceRandom[(trialIdx - 2)]))) {&amp;#10;            threeconsletters[trialIdx] = true;&amp;#10;        }&amp;#10;    }&amp;#10;    threeconsmatches = np.zeros(trialAll_num, {&quot;dtype&quot;: bool});&amp;#10;    for (var trialIdx, _pj_c = 0, _pj_a = np.arange(2, trialAll_num), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;        trialIdx = _pj_a[_pj_c];&amp;#10;        if ((util.sum(trialMatch_observed.slice((trialIdx - 2), (trialIdx + 1))) === 3)) {&amp;#10;            threeconsmatches[trialIdx] = true;&amp;#10;        }&amp;#10;    }&amp;#10;    if ((((trialMatch_num_observed === trialMatch_num_expected) &amp;&amp; (util.sum(threeconsmatches) === 0)) &amp;&amp; (util.sum(threeconsletters) === 0))) {&amp;#10;        toggleSwitch = false;&amp;#10;    }&amp;#10;}&amp;#10;sequenceOk = sequenceRandom;&amp;#10;expectedResponse = np.array(function () {&amp;#10;    var _pj_a = [], _pj_b = np.arange(trialAll_num);&amp;#10;    for (var _pj_c = 0, _pj_d = _pj_b.length; (_pj_c &lt; _pj_d); _pj_c += 1) {&amp;#10;        var _ = _pj_b[_pj_c];&amp;#10;        _pj_a.push(&quot;key2use&quot;);&amp;#10;    }&amp;#10;    return _pj_a;&amp;#10;}&amp;#10;.call(this));&amp;#10;expectedResponse[(trialMatch_observed === true)] = &quot;left&quot;;&amp;#10;expectedResponse[(trialMatch_observed === false)] = &quot;right&quot;;&amp;#10;sequenceDataset = new pd.DataFrame({&quot;trial&quot;: np.arange(1, (trialAll_num + 1)), &quot;letter&quot;: sequenceOk, &quot;nback_match&quot;: trialMatch_observed, &quot;expectedResponse&quot;: expectedResponse, &quot;observedResponse&quot;: np.nan, &quot;Accuracy&quot;: np.nan, &quot;RT_allTrials&quot;: np.nan, &quot;RT_correctTrials&quot;: np.nan});&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="rowCounter = -1" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="&quot;&quot;&quot;&amp;#10;GENERATE LISTS OF spatial-updating STIMULI&amp;#10;&quot;&quot;&quot;&amp;#10;&amp;#10;import numpy as np&amp;#10;import pandas as pd&amp;#10;&amp;#10;trial_num = 9 # use 2(practice) or 18(experiment)&amp;#10;grid_num = 12 # use: 10(practice) or 12(experiment)&amp;#10;stim_num = trial_num * grid_num  # total number of grids (20 practice, 216 experiment)&amp;#10;&amp;#10;# create trial, grid, stimulus columns&amp;#10;trial = np.repeat(1+np.arange(0,trial_num),grid_num)&amp;#10;grid  = np.tile(1+np.arange(0,grid_num),trial_num)&amp;#10;stimulus = 1+np.arange(0,stim_num)&amp;#10;&amp;#10;&amp;#10;# %% create sequence &amp;#10;&amp;#10;# big pool of colors&amp;#10;color_bigPool = [&quot;blu&quot;, &quot;gre&quot;, &quot;red&quot;, &quot;yel&quot;] &amp;#10;&amp;#10;color    = np.empty(stim_num,dtype=&quot;&lt;U3&quot;) # initialize &amp;#10;position = np.empty(stim_num,dtype=&quot;&lt;U1&quot;) # initialize &amp;#10;expectedResponse_blu = np.empty(stim_num,dtype=&quot;&lt;U5&quot;) # initialize&amp;#10;expectedResponse_gre = np.empty(stim_num,dtype=&quot;&lt;U5&quot;) # initialize&amp;#10;expectedResponse_red = np.empty(stim_num,dtype=&quot;&lt;U5&quot;) # initialize&amp;#10;expectedResponse_yel = np.empty(stim_num,dtype=&quot;&lt;U5&quot;) # initialize&amp;#10;&amp;#10;for trialIdx in np.arange(0,trial_num):&amp;#10;    &amp;#10;    numCol = 3 # number of colors in use within this trial&amp;#10;    color_pool = np.random.choice(color_bigPool,numCol,False)  # pick n colors within a trial&amp;#10;    color_pool = list(color_pool)  # convert np.array to list&amp;#10;    &amp;#10;    # %% create color_grid column (the list of colors within this trial)&amp;#10;    # criteria:&amp;#10;    # 1. not the same color consecutively&amp;#10;    # 2. each color is presented at least twice&amp;#10;    toggleSwitch = 1&amp;#10;    while toggleSwitch==1:&amp;#10;        &amp;#10;        color_grid = np.empty(grid_num,dtype=&quot;&lt;U3&quot;) # initialize &amp;#10;        for gridIdx in np.arange(0,grid_num):&amp;#10;            &amp;#10;            if grid[gridIdx]==1: # 1st grid&amp;#10;                # pick any color&amp;#10;                color_grid[gridIdx]  = np.random.choice(color_pool,1)[0]&amp;#10;                &amp;#10;            elif grid[gridIdx]&gt;=2: # 2nd trial and onwards&amp;#10;             # &quot;criterion 1&quot;: pick any color except the one presented before&amp;#10;                color_pool_red  = np.delete(color_pool,   color_pool.index(color_grid[gridIdx-1]) )  # reduced pool &amp;#10;                color_grid[gridIdx]  = np.random.choice(color_pool_red,1)[0]&amp;#10;    &amp;#10;        # &quot;criterion 2&quot;: each color is presented at least twice but not more than five times&amp;#10;        colorSum  = np.empty(len(color_pool),dtype=int)     &amp;#10;        for poolIdx in np.arange(0,len(color_pool)):&amp;#10;            colorSum[poolIdx]  = sum(color_grid==color_pool[poolIdx])&amp;#10;         &amp;#10;        # implements criterion 2 check above (keep asking for a new sequence if the check fails)&amp;#10;        if np.min(colorSum)&gt;=2  and  np.max(colorSum)&lt;=5:&amp;#10;            toggleSwitch = 0    &amp;#10;&amp;#10;    # %% create position_grid column (the list of positions within this trial)&amp;#10;    # criteria:&amp;#10;    # 1. always a different position_grid for each color&amp;#10;        &amp;#10;    # pool of position_grids (separate for each color) based on the numeric pad (e.g., 1=bottom-left, 9=top-right)&amp;#10;    blu_pos_pool = 1+np.arange(0,9)&amp;#10;    gre_pos_pool = 1+np.arange(0,9)&amp;#10;    red_pos_pool = 1+np.arange(0,9)&amp;#10;    yel_pos_pool = 1+np.arange(0,9)&amp;#10;        &amp;#10;    # shuffle the position_grids (separately for each color)&amp;#10;    np.random.shuffle(blu_pos_pool)&amp;#10;    np.random.shuffle(gre_pos_pool)&amp;#10;    np.random.shuffle(red_pos_pool)&amp;#10;    np.random.shuffle(yel_pos_pool)&amp;#10;    &amp;#10;    # initialize color counter&amp;#10;    bluIdx = -1&amp;#10;    greIdx = -1&amp;#10;    redIdx = -1&amp;#10;    yelIdx = -1&amp;#10;    position_grid = np.zeros(grid_num,dtype=int) # initialize &amp;#10;&amp;#10;    for gridIdx in np.arange(0,grid_num):&amp;#10;        if color_grid[gridIdx]==&quot;blu&quot;:&amp;#10;            bluIdx = bluIdx + 1 # increase the counter&amp;#10;            position_grid[gridIdx]  = blu_pos_pool[bluIdx] # pick sequentially from the (shuffled) pool for this specific color&amp;#10;        &amp;#10;        elif color_grid[gridIdx]==&quot;gre&quot;:&amp;#10;            greIdx = greIdx + 1 # increase the counter&amp;#10;            position_grid[gridIdx]  = gre_pos_pool[greIdx] # pick sequentially from the (shuffled) pool for this specific color&amp;#10;&amp;#10;        elif color_grid[gridIdx]==&quot;red&quot;:&amp;#10;            redIdx = redIdx + 1 # increase the counter&amp;#10;            position_grid[gridIdx]  = red_pos_pool[redIdx] # pick sequentially from the (shuffled) pool for this specific color&amp;#10;            &amp;#10;        elif color_grid[gridIdx]==&quot;yel&quot;:&amp;#10;            yelIdx = yelIdx + 1 # increase the counter&amp;#10;            position_grid[gridIdx]  = yel_pos_pool[yelIdx] # pick sequentially from the (shuffled) pool for this specific color&amp;#10;    &amp;#10;&amp;#10;    # %% create expectedResponse (separate per each color and combined)&amp;#10;    # find the last position for each color, only if this color was presented in the trial&amp;#10;&amp;#10;    expectedResponse_blu_grid = np.empty(grid_num,dtype=&quot;&lt;U5&quot;) # initialize &amp;#10;    if &quot;blu&quot; in color_pool:&amp;#10;        expectedResponse_blu_grid[gridIdx] = np.char.add(&quot;num_&quot;, np.asarray(blu_pos_pool[bluIdx],dtype=&quot;&lt;U1&quot;))&amp;#10;    &amp;#10;    expectedResponse_gre_grid = np.empty(grid_num,dtype=&quot;&lt;U5&quot;) # initialize &amp;#10;    if &quot;gre&quot; in color_pool:&amp;#10;        expectedResponse_gre_grid[gridIdx] = np.char.add(&quot;num_&quot;, np.asarray(gre_pos_pool[greIdx],dtype=&quot;&lt;U1&quot;))&amp;#10;&amp;#10;    expectedResponse_red_grid = np.empty(grid_num,dtype=&quot;&lt;U5&quot;) # initialize &amp;#10;    if &quot;red&quot; in color_pool:&amp;#10;        expectedResponse_red_grid[gridIdx] = np.char.add(&quot;num_&quot;, np.asarray(red_pos_pool[redIdx],dtype=&quot;&lt;U1&quot;))&amp;#10;&amp;#10;    expectedResponse_yel_grid = np.empty(grid_num,dtype=&quot;&lt;U5&quot;) # initialize &amp;#10;    if &quot;yel&quot; in color_pool:&amp;#10;        expectedResponse_yel_grid[gridIdx] = np.char.add(&quot;num_&quot;, np.asarray(yel_pos_pool[yelIdx],dtype=&quot;&lt;U1&quot;))&amp;#10;    # %% add these grids to the current trial         &amp;#10;    &amp;#10;    color[trial==trialIdx+1] = color_grid&amp;#10;    position[trial==trialIdx+1] = position_grid&amp;#10;    expectedResponse_blu[trial==trialIdx+1] = expectedResponse_blu_grid&amp;#10;    expectedResponse_gre[trial==trialIdx+1] = expectedResponse_gre_grid&amp;#10;    expectedResponse_red[trial==trialIdx+1] = expectedResponse_red_grid&amp;#10;    expectedResponse_yel[trial==trialIdx+1] = expectedResponse_yel_grid&amp;#10;&amp;#10;&amp;#10;# %% create gridName (i.e., color + position)&amp;#10;&amp;#10;gridName = np.char.add(np.char.add(color, np.repeat(&quot;_&quot;,len(color))), np.asarray(position, dtype='&lt;U1'))&amp;#10;&amp;#10;# %% create dataset&amp;#10;# build a dataframe from dictionary&amp;#10;&amp;#10;sequenceDataset= pd.DataFrame({'trial': trial,&amp;#10;                               'grid': grid,&amp;#10;                               'stimulus': stimulus,&amp;#10;                               'color': color,&amp;#10;                               'position': position,&amp;#10;                               'gridName': gridName,&amp;#10;                               'expectedResponse_blu': expectedResponse_blu,&amp;#10;                               'observedResponse_blu': np.empty(len(trial),dtype=&quot;&lt;U5&quot;),&amp;#10;                               'Accuracy_blu': np.nan,&amp;#10;                               'expectedResponse_gre': expectedResponse_gre,&amp;#10;                               'observedResponse_gre': np.empty(len(trial),dtype=&quot;&lt;U5&quot;),&amp;#10;                               'Accuracy_gre': np.nan,&amp;#10;                               'expectedResponse_red': expectedResponse_red,&amp;#10;                               'observedResponse_red': np.empty(len(trial),dtype=&quot;&lt;U5&quot;),&amp;#10;                               'Accuracy_red': np.nan,&amp;#10;                               'expectedResponse_yel': expectedResponse_yel,&amp;#10;                               'observedResponse_yel': np.empty(len(trial),dtype=&quot;&lt;U5&quot;),&amp;#10;                               'Accuracy_yel': np.nan,&amp;#10;                               'Accuracy_tot': np.nan,&amp;#10;                               'RespTime_grid': np.nan,&amp;#10;                               'gridDuration': np.nan,&amp;#10;                               'step': np.nan})" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="stimuli_2" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
