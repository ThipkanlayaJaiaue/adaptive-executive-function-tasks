      <CodeComponent name="addData_2" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="psychoJS.experiment.addData(&quot;otherInfo.trial&quot;, sequenceDataset.trial[practiceBlock.thisN]);&amp;#10;psychoJS.experiment.addData(&quot;otherInfo.letter&quot;, sequenceDataset.letter[practiceBlock.thisN]);&amp;#10;psychoJS.experiment.addData(&quot;otherInfo.nback_match&quot;, sequenceDataset.nback_match[practiceBlock.thisN]);&amp;#10;psychoJS.experiment.addData(&quot;otherInfo.expectedResponse&quot;, sequenceDataset.expectedResponse[practiceBlock.thisN]);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="rowCounter = rowCounter + 1&amp;#10;&amp;#10;&amp;#10;# adaptive duration &amp;#10;if sequenceDataset.trial[rowCounter]==1:&amp;#10;    #sequenceDataset.gridDuration[rowCounter] = Practice_grid_MdnRT   # for first trial, use Median ResponseTimes from practice block grids&amp;#10;    sequenceDataset.gridDuration[rowCounter] = Practice_grid_3qrtRT  # for first trial, use 3rd qrt ResponseTimes from practice block grids&amp;#10;else:&amp;#10;    if sequenceDataset.grid[rowCounter]==1:&amp;#10;        sequenceDataset.gridDuration[rowCounter] = sequenceDataset.gridDuration[rowCounter-1] + sequenceDataset.step[rowCounter-1]   &amp;#10;        # for the first grid of the next trials add a step value depending on previous trial accuracy to the duration of the grids in the previous trial&amp;#10;    else:&amp;#10;        sequenceDataset.gridDuration[rowCounter] = sequenceDataset.gridDuration[rowCounter-1] &amp;#10;        # for the second grid onwards of the next trials maintain the same duration as the first grid of this trial&amp;#10;&amp;#10;&amp;#10;# add data about the sequence&amp;#10;thisExp.addData('myExp.trial',    sequenceDataset.trial[rowCounter])&amp;#10;thisExp.addData('myExp.grid',     sequenceDataset.grid[rowCounter])&amp;#10;thisExp.addData('myExp.stimulus', sequenceDataset.stimulus[rowCounter])&amp;#10;&amp;#10;thisExp.addData('myExp.color',     sequenceDataset.color[rowCounter])&amp;#10;thisExp.addData('myExp.position',  sequenceDataset.position[rowCounter])&amp;#10;thisExp.addData('myExp.gridName',  sequenceDataset.gridName[rowCounter])&amp;#10;&amp;#10;thisExp.addData('myExp.gridDuration',  sequenceDataset.gridDuration[rowCounter])" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
